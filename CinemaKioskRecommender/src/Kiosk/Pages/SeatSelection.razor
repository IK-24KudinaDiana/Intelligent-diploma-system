@page "/seats/{SessionId:guid}"
@layout CinemaKioskRecommender.Kiosk.Layout.ShellLayout

@using CinemaKioskRecommender.Application.DTOs
@using CinemaKioskRecommender.Kiosk.Services
@using CinemaKioskRecommender.Kiosk.Localization
@using MudBlazor
@implements IAsyncDisposable
@inject AiCommandListenerService AiListener

@inject HttpClient Http
@inject NavigationManager Nav
@inject KioskState State

<div class="seats-screen">

    <div class="seats-wrapper">
        <div class="seats-header">

            <h1 class="seats-title">
                Вибір місць
            </h1>

            <div class="seats-subtitle">
                @Session?.MovieTitle
            </div>

            <div class="seats-meta">
                @Session?.HallName •
                @Session?.StartTime.ToString("dd.MM.yyyy • HH:mm")
            </div>

        </div>
        <div class="cinema-screen-wrap">

            <div class="screen-glow"></div>

            <div class="cinema-screen">
                ЕКРАН
            </div>

        </div>
        <div class="hall-layout">
            <div class="hall-seats-card">

                <div class="seats-grid">

                    @foreach (var row in SeatsByRow)
                    {
                        <div class="seat-row">

                            <div class="row-label">
                                @row.Key
                            </div>

                            <div class="row-seats">

                                @foreach (var seat in row.Value)
                                {
                                    <button class="@($"seat-btn {GetSeatClass(seat)}")"
                                            disabled="@seat.IsOccupied"
                                            @onclick="() => ToggleSeat(seat.SeatNumber)">

                                        @seat.SeatNumber.Substring(1)

                                    </button>
                                }

                            </div>

                        </div>
                    }

                </div>

            </div>
            <div class="selected-panel">

                <div class="panel-title">
                    Вибрані місця
                </div>

                @if (SelectedSeats.Any())
                {
                    <div class="selected-seats-list">

                        @foreach (var seat in SelectedSeats)
                        {
                            <div class="selected-seat-chip">
                                @seat
                            </div>
                        }

                    </div>

                    <div class="vip-info">
                        @UiStrings.VipIncluded
                    </div>

                    <div class="panel-divider"></div>

                    <div class="total-section">

                        <div class="total-label">
                            До сплати
                        </div>

                        <div class="total-price">
                            @State.TotalPrice грн
                        </div>

                    </div>
                }
                else
                {
                    <div class="empty-selection">
                        Оберіть місця на схемі залу
                    </div>
                }

            </div>

        </div>
        <div class="legend">

            <div class="legend-item">
                <span class="legend-dot available"></span>
                Вільне
            </div>

            <div class="legend-item">
                <span class="legend-dot selected"></span>
                Вибрано
            </div>

            <div class="legend-item">
                <span class="legend-dot occupied"></span>
                Зайнято
            </div>

        </div>
        <div class="checkout-wrap">

            <button class="checkout-btn"
                    disabled="@(!SelectedSeats.Any())"
                    @onclick="GoToPayment">

                Продовжити до оплати

            </button>

        </div>

    </div>

</div>

<style>

    .seats-screen {
        width: 100%;
        min-height: 100%;
        padding: clamp(28px, 3vw, 48px) clamp(20px, 3.2vw, 64px) clamp(42px, 5vw, 80px);
        background: transparent;
        position: relative;
        overflow: auto;
    }

        .seats-screen::before {
            display: none;
        }

    .seats-wrapper {
        width: 100%;
        position: relative;
        z-index: 2;
    }

    .seats-header {
        text-align: center;
        margin-bottom: 42px;
    }

    .seats-title {
        margin: 0;
        color: white;
        font-size: 56px;
        font-weight: 800;
        letter-spacing: -2px;
    }

    .seats-subtitle {
        margin-top: 14px;
        color: white;
        font-size: 28px;
        font-weight: 600;
    }

    .seats-meta {
        margin-top: 10px;
        color: rgba(255,255,255,.62);
        font-size: 18px;
    }

    .cinema-screen-wrap {
        position: relative;
        display: flex;
        justify-content: center;
        margin-bottom: 70px;
    }

    .screen-glow {
        position: absolute;
        top: 10px;
        width: 70%;
        height: 90px;
        background: rgba(255,255,255,.15);
        filter: blur(80px);
    }

    .cinema-screen {
        width: 75%;
        max-width: 950px;
        height: 100px;
        border-radius: 26px;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #dbeafe;
        font-size: 34px;
        font-weight: 800;
        letter-spacing: 18px;
        background: linear-gradient( 180deg, rgba(255,255,255,.16), rgba(255,255,255,.04));
        border: 1px solid rgba(255,255,255,.14);
        box-shadow: 0 25px 80px rgba(0,0,0,.55), 0 0 40px rgba(96,165,250,.18);
        backdrop-filter: blur(18px);
    }

    .hall-layout {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 34px;
        align-items: start;
    }

    .hall-seats-card {
        padding: 36px;
        border-radius: 34px;
        background: linear-gradient( 180deg, rgba(16,22,35,.92), rgba(10,13,20,.94));
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(24px);
        box-shadow: 0 20px 80px rgba(0,0,0,.5);
    }

    .seats-grid {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .seat-row {
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .row-label {
        width: 34px;
        color: #dbeafe;
        font-size: 28px;
        font-weight: 800;
        text-align: center;
    }

    .row-seats {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .seat-btn {
        width: 62px;
        height: 62px;
        border: none;
        border-radius: 18px;
        font-size: 18px;
        font-weight: 700;
        transition: .22s ease;
        cursor: pointer;
    }

        .seat-btn.available {
            background: #173b8f;
            color: white;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 10px 24px rgba(0,0,0,.45);
        }

            .seat-btn.available:hover {
                transform: scale(1.1);
                background: #2563eb;
            }

        .seat-btn.selected {
            background: #22d3ee;
            color: #03131a;
            transform: scale(1.12);
            box-shadow: 0 0 24px rgba(34,211,238,.8), 0 0 50px rgba(34,211,238,.45);
        }

        .seat-btn.occupied {
            background: #3b4454;
            color: #9ca3af;
            cursor: not-allowed;
            opacity: .7;
        }

    .selected-panel {
        position: sticky;
        top: 30px;
        padding: 30px;
        border-radius: 34px;
        background: linear-gradient( 180deg, rgba(16,22,35,.92), rgba(10,13,20,.94));
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(24px);
        box-shadow: 0 20px 80px rgba(0,0,0,.45);
    }

    .panel-title {
        color: white;
        font-size: 28px;
        font-weight: 800;
    }

    .selected-seats-list {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
    }

    .selected-seat-chip {
        padding: 14px 18px;
        border-radius: 16px;
        background: linear-gradient( 135deg, rgba(34,211,238,.24), rgba(59,130,246,.18));
        border: 1px solid rgba(34,211,238,.25);
        color: #67e8f9;
        font-size: 18px;
        font-weight: 700;
        box-shadow: 0 0 20px rgba(34,211,238,.18);
    }

    .vip-info {
        margin-top: 24px;
        color: #a78bfa;
        font-size: 16px;
        font-weight: 600;
    }

    .panel-divider {
        height: 1px;
        background: rgba(255,255,255,.08);
        margin: 28px 0;
    }

    .total-label {
        color: rgba(255,255,255,.55);
        font-size: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .total-price {
        margin-top: 12px;
        color: #37ffb1;
        font-size: 46px;
        font-weight: 800;
        text-shadow: 0 0 25px rgba(55,255,177,.22);
    }

    .empty-selection {
        margin-top: 26px;
        color: rgba(255,255,255,.52);
        line-height: 1.7;
    }

    .legend {
        margin-top: 42px;
        display: flex;
        justify-content: center;
        gap: 42px;
        flex-wrap: wrap;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #e5e7eb;
        font-size: 18px;
    }

    .legend-dot {
        width: 22px;
        height: 22px;
        border-radius: 50%;
    }

        .legend-dot.available {
            background: #2563eb;
        }

        .legend-dot.selected {
            background: #22d3ee;
            box-shadow: 0 0 18px rgba(34,211,238,.65);
        }

        .legend-dot.occupied {
            background: #4b5563;
        }

    .checkout-wrap {
        margin-top: 46px;
        display: flex;
        justify-content: center;
    }

    .checkout-btn {
        min-width: 420px;
        height: 82px;
        border: none;
        border-radius: 24px;
        color: white;
        font-size: 24px;
        font-weight: 800;
        cursor: pointer;
        transition: .25s ease;
        background: linear-gradient( 135deg, #4f8cff 0%, #7c4dff 100%);
        box-shadow: 0 16px 45px rgba(79,140,255,.35);
    }

        .checkout-btn:hover:not(:disabled) {
            transform: translateY(-2px) scale(1.01);
        }

        .checkout-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    @@media(max-width:1200px) {

        .hall-layout {
            grid-template-columns: 1fr;
        }

        .selected-panel {
            position: relative;
            top: 0;
        }
    }

    @@media(max-width:768px) {

        .seats-title {
            font-size: 40px;
        }

        .seats-subtitle {
            font-size: 22px;
        }

        .cinema-screen {
            width: 95%;
            height: 82px;
            font-size: 24px;
            letter-spacing: 10px;
        }

        .hall-seats-card {
            padding: 18px;
        }

        .seat-row {
            gap: 10px;
        }

        .seat-btn {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            font-size: 15px;
        }

        .checkout-btn {
            width: 100%;
            min-width: unset;
            font-size: 20px;
        }
    }

</style>

@code {

    [Parameter]
    public Guid SessionId { get; set; }

    private SessionDto? Session { get; set; }

    private List<SeatDto> AllSeats { get; set; } = new();

    private Dictionary<string, List<SeatDto>> SeatsByRow { get; set; } = new();

    private List<string> SelectedSeats { get; set; } = new();

    [Inject] private ILogger<SeatSelection>? Logger { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Session = await Http.GetFromJsonAsync<SessionDto>(
            $"api/sessions/{SessionId}");

        var response =
            await Http.GetFromJsonAsync<List<SeatDto>>(
                $"api/sessions/{SessionId}/seats");

        AllSeats = response ?? new();

        SeatsByRow = AllSeats
            .GroupBy(s => s.SeatNumber.Substring(0, 1))
            .OrderBy(g => g.Key)
            .ToDictionary(
                g => g.Key,
                g => g.OrderBy(s =>
                    int.Parse(s.SeatNumber[1..]))
                .ToList());

        if (Session != null)
        {
            State.SetCurrentSession(
                Session.Id,
                Session.MovieTitle,
                Session.HallName,
                Session.StartTime,
                Session.Price);
        }

        if (State.AiSessionId is not null)
            AiListener.CommandReceived += OnAiCommandAsync;
    }

    private async Task OnAiCommandAsync(AiCommandDto command)
    {
        switch (command.Command)
        {
            case "select_seats":
            {
                var seats = SeatNumberHelper.ExpandSeatInputs(
                    AiPayloadHelper.GetStringList(command.Payload, "seats"));
                var knownSeatNumbers = AllSeats.Select(s => s.SeatNumber);
                SelectedSeats.Clear();
                foreach (var seat in seats)
                {
                    var normalized = SeatNumberHelper.Normalize(seat, knownSeatNumbers);
                    if (AllSeats.Any(s => s.SeatNumber == normalized && !s.IsOccupied)
                        && !SelectedSeats.Contains(normalized))
                        SelectedSeats.Add(normalized);
                }

                State.SetSelectedSeats(SelectedSeats);
                await InvokeAsync(StateHasChanged);
                break;
            }
            case "proceed_to_payment":
                if (SelectedSeats.Any())
                    await InvokeAsync(GoToPayment);
                break;
        }
    }

    private void ToggleSeat(string seatNumber)
    {
        if (SelectedSeats.Contains(seatNumber))
        {
            SelectedSeats.Remove(seatNumber);
        }
        else if (SelectedSeats.Count < 8)
        {
            SelectedSeats.Add(seatNumber);
        }

        State.SetSelectedSeats(SelectedSeats.ToList());

        StateHasChanged();
    }

    private async Task GoToPayment()
    {
        if (!SelectedSeats.Any())
            return;

        State.SetSelectedSeats(SelectedSeats.ToList());
        Nav.NavigateTo($"/payment/{SessionId}");
    }

    private string GetSeatClass(SeatDto seat)
    {
        if (seat.IsOccupied)
            return "occupied";

        if (SelectedSeats.Contains(seat.SeatNumber))
            return "selected";

        return "available";
    }

    public async ValueTask DisposeAsync()
    {
        AiListener.CommandReceived -= OnAiCommandAsync;
        await Task.CompletedTask;
    }
}
